# Production environment template (Task 26.1).
# All secrets are REQUIRED in production; the loader fails fast if any is missing.
# Provide real values via your secret manager / CI — do NOT commit secrets.

APP_ENV=production
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://pms.example.com
DATABASE_URL=postgresql://USER:PASSWORD@prod-db.example.com:5432/pms_production
PMS_FEATURE_FLAGS=
PMS_DEFAULT_PAGE_SIZE=25
