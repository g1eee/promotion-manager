# Staging environment template (Task 26.1).
# All secrets are REQUIRED in staging; the loader fails fast if any is missing.
# Provide real values via your secret manager / CI — do NOT commit secrets.

APP_ENV=staging
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://staging.pms.example.com
DATABASE_URL=postgresql://USER:PASSWORD@staging-db.example.com:5432/pms_staging
PMS_FEATURE_FLAGS=
PMS_DEFAULT_PAGE_SIZE=25
