# ---------------------------------------------------------------------------
# Promotion Management System — environment variables
# Copy this file to `.env.local` and fill in real values. Do NOT commit secrets.
# Per-environment templates: .env.development, .env.staging, .env.production
# ---------------------------------------------------------------------------

# Deployment environment: development | staging | production
# When unset, NODE_ENV is used and falls back to "development".
APP_ENV=development

# Authentication (NextAuth / Auth.js)
# -----------------------------------
# Secret used to sign/encrypt session tokens (JWT). Generate one with:
#   npx auth secret      (or)      openssl rand -base64 32
# REQUIRED in staging/production; a dev default is applied in development.
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Canonical base URL of the app. Used for auth callbacks/redirects.
NEXTAUTH_URL=http://localhost:3000

# Database
# --------
# Postgres connection string (Prisma). REQUIRED in staging/production.
DATABASE_URL=postgresql://localhost:5432/pms_dev

# Application parameters
# ----------------------
# Comma-separated feature flags (e.g. "attachments,combined-execution").
PMS_FEATURE_FLAGS=
# Default page size for paginated listings (positive integer).
PMS_DEFAULT_PAGE_SIZE=25
