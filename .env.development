# Development environment template (Task 26.1).
# Copy to `.env.development.local` or `.env.local` for local runs.
# Development applies safe localhost defaults, so values here are optional.

APP_ENV=development
NEXTAUTH_SECRET=dev-insecure-secret-change-me
NEXTAUTH_URL=http://localhost:3000
DATABASE_URL=postgresql://localhost:5432/pms_dev
PMS_FEATURE_FLAGS=
PMS_DEFAULT_PAGE_SIZE=25
